<!DOCTYPE html>

<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Erica carnea</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body {
  width:100%; height:100%; overflow:hidden;
  background:#0c0907;
  display:flex; align-items:center; justify-content:center;
  font-family: 'Georgia', serif;
  touch-action:none;
  -webkit-tap-highlight-color:transparent;
  -webkit-user-select:none; user-select:none;
}
#cv { display:block; }
.ui { position:fixed; inset:0; pointer-events:none; z-index:10; }
.title {
  position:fixed; top:18px; left:22px;
  font-style:italic; font-weight:300; font-size:15px;
  letter-spacing:4px; color:rgba(210,185,155,0.5);
}
.sub {
  position:fixed; top:42px; left:22px;
  font-size:9px; letter-spacing:3px; text-transform:uppercase;
  font-family:monospace; color:rgba(160,135,110,0.30);
}
.stage {
  position:fixed; bottom:22px; left:22px;
  font-size:9px; letter-spacing:3px; text-transform:uppercase;
  font-family:monospace; color:rgba(195,168,138,0.55);
  transition: color 1.2s ease;
}
.stage.red { color:rgba(200,110,90,0.70); }
.hints {
  position:fixed; bottom:22px; right:22px;
  font-size:8px; letter-spacing:2px;
  font-family:monospace; color:rgba(150,130,108,0.28);
  text-align:right; line-height:2;
}
.speed-tag {
  position:fixed; top:18px; right:22px;
  font-family:monospace; font-size:8px; letter-spacing:3px;
  text-transform:uppercase; color:rgba(185,158,128,0.55);
  padding:4px 10px; border:1px solid rgba(180,150,120,0.2);
  border-radius:20px; opacity:0; transition:opacity .3s ease;
}
.speed-tag.show { opacity:1; }
.restart-btn {
  position:fixed; bottom:52px; left:50%; transform:translateX(-50%);
  pointer-events:all; cursor:pointer;
  background:rgba(80,50,25,0.5); border:1px solid rgba(150,110,70,0.35);
  color:rgba(210,185,155,0.65); font-family:monospace;
  font-size:9px; letter-spacing:3px; padding:8px 20px;
  border-radius:20px; text-transform:uppercase;
  transition: all .3s ease;
}
.restart-btn:hover { background:rgba(100,65,30,0.6); color:rgba(230,205,175,0.85); }
</style>
</head>
<body>
<canvas id="cv"></canvas>
<div class="ui">
  <div class="title">Erica carnea</div>
  <div class="sub">시들다 · Seoul 2026</div>
  <div class="stage" id="stageEl">STAGE 01 / 10 · LIVING</div>
  <div class="hints">TOUCH · FASTER<br>STEM DRAG ↕ · SLOWER</div>
  <div class="speed-tag" id="speedTag">▲ FAST</div>
</div>
<button class="restart-btn" id="restartBtn" onclick="restart()">↺ RESTART</button>

<script>
const cv = document.getElementById('cv');
const ctx = cv.getContext('2d');
let W, H, SC;

function resize() {
  const vw = window.innerWidth, vh = window.innerHeight;
  W = Math.min(vw, 480);
  H = Math.min(vh, 680);
  if(W/H < 0.55) W = H * 0.55;
  if(H/W > 1.55) H = W * 1.55;
  W = Math.max(W, 280); H = Math.max(H, 400);
  cv.width  = W; cv.height = H;
  cv.style.width  = W+'px'; cv.style.height = H+'px';
  SC = Math.min(W,H)/500;
}
resize();
window.addEventListener('resize', ()=>{ resize(); buildPlant(); });

// ── RNG ──
let _sd = 0xA8B3C4;
function rng(){ _sd^=_sd<<13; _sd^=_sd>>17; _sd^=_sd<<5; return(_sd>>>0)/0xFFFFFFFF; }
function resetRng(){ _sd=0xA8B3C4; }

// ── STAGE DATA ──
const STAGES=[
  {stem:[44,112,36],lf:[55,140,44],f1:[235,92,162],f2:[200,52,140],bg:[12,9,7]},
  {stem:[55,108,33],lf:[62,130,38],f1:[220,80,150],f2:[188,44,130],bg:[13,9,7]},
  {stem:[72,102,28],lf:[76,118,30],f1:[202,68,132],f2:[172,36,114],bg:[13,10,7]},
  {stem:[92,100,22],lf:[90,108,22],f1:[176,56,112],f2:[152,28,97], bg:[14,10,7]},
  {stem:[118,98,18],lf:[104,98,16],f1:[150,44,90], f2:[128,22,75], bg:[14,11,8]},
  {stem:[132,86,14],lf:[112,82,11],f1:[120,34,68], f2:[100,16,56], bg:[15,11,8]},
  {stem:[122,72,10],lf:[95,64,7],  f1:[92,24,50],  f2:[76,10,40],  bg:[15,11,8]},
  {stem:[102,54,7], lf:[74,47,5],  f1:[66,16,35],  f2:[52,8,28],   bg:[14,10,7]},
  {stem:[78,38,4],  lf:[54,33,3],  f1:[42,10,22],  f2:[32,6,17],   bg:[13,9,6]},
  {stem:[48,22,2],  lf:[30,20,2],  f1:[24,5,12],   f2:[16,3,9],    bg:[10,7,5]},
];
const DROOP   =[0,.03,.09,.17,.28,.41,.56,.70,.84,.97];
const FSCALE  =[1.0,.99,.97,.93,.86,.76,.63,.49,.34,.21];
const SHRIVEL =[0,.01,.04,.10,.18,.29,.42,.57,.73,.89];
const LABELS  =['LIVING','LIVING','FADING','FADING','WILTING','WILTING','DRYING','DRYING','DYING','DEAD'];

// ── HELPERS ──
function lerp(a,b,t){ return a+(b-a)*t; }
function clamp(v,lo,hi){ return Math.max(lo,Math.min(hi,v)); }
function lerpC(a,b,t){ return [(lerp(a[0],b[0],t))|0,(lerp(a[1],b[1],t))|0,(lerp(a[2],b[2],t))|0]; }
function col(arr,a){ return a!==undefined?`rgba(${arr[0]},${arr[1]},${arr[2]},${a.toFixed(3)})`:`rgb(${arr[0]},${arr[1]},${arr[2]})`; }
function qPt(x0,y0,cx0,cy0,x1,y1,t){ const m=1-t; return{x:m*m*x0+2*m*t*cx0+t*t*x1,y:m*m*y0+2*m*t*cy0+t*t*y1}; }
function qTan(x0,y0,cx0,cy0,x1,y1,t){ return Math.atan2(2*(1-t)*(cy0-y0)+2*t*(y1-cy0),2*(1-t)*(cx0-x0)+2*t*(x1-cx0)); }
function cPt(b,t){ const m=1-t; return{x:m*m*m*b.x0+3*m*m*t*b.x1+3*m*t*t*b.x2+t*t*t*b.x3,y:m*m*m*b.y0+3*m*m*t*b.y1+3*m*t*t*b.y2+t*t*t*b.y3}; }
function cTan(b,t){ const m=1-t; return{dx:3*m*m*(b.x1-b.x0)+6*m*t*(b.x2-b.x1)+3*t*t*(b.x3-b.x2),dy:3*m*m*(b.y1-b.y0)+6*m*t*(b.y2-b.y1)+3*t*t*(b.y3-b.y2)}; }

function getParams(prog){
  const si=clamp(Math.floor(prog),0,8); const sf=prog-si;
  const A=STAGES[si],B=STAGES[si+1];
  return{
    stem:lerpC(A.stem,B.stem,sf), lf:lerpC(A.lf,B.lf,sf),
    f1:lerpC(A.f1,B.f1,sf), f2:lerpC(A.f2,B.f2,sf), bg:lerpC(A.bg,B.bg,sf),
    droop:lerp(DROOP[si],DROOP[si+1],sf), fscale:lerp(FSCALE[si],FSCALE[si+1],sf),
    shrivel:lerp(SHRIVEL[si],SHRIVEL[si+1],sf),
  };
}

// ── PLANT BUILD ──
let PLANT=null;
function buildPlant(){
  resetRng();
  const bx=W*0.50, by=H*0.865, sh=H*0.60;
  const ms={x0:bx,y0:by,x1:bx+(rng()-.5)*22,y1:by-sh*.30,x2:bx+(rng()-.5)*18,y2:by-sh*.62,x3:bx+(rng()-.5)*10,y3:by-sh};
  const branches=[];
  const N_BR=16;
  for(let i=0;i<N_BR;i++){
    const tS=0.07+(i/(N_BR-1))*0.88;
    const origin=cPt(ms,tS);
    const tan=cTan(ms,tS);
    const sa=Math.atan2(tan.dy,tan.dx);
    const side=(i%2===0)?-1:1;
    const spread=Math.PI/5+rng()*Math.PI/8;
    const tiltUp=(0.2+rng()*0.25)*(1-tS*0.4);
    const brAngle=sa+(Math.PI/2)*side-spread*side-tiltUp;
    const brLen=(38+rng()*55)*SC;
    const subs=[];
    const nSub=4+Math.floor(rng()*5);
    for(let j=0;j<nSub;j++){
      const tBr=0.12+(j/(nSub-1))*0.82;
      const subSide=(j%2===0)?-1:1;
      const subAngle=brAngle+subSide*(Math.PI/9+rng()*Math.PI/12)+(rng()-.5)*0.2;
      const subLen=(13+rng()*22)*SC;
      const flowers=[];
      const nF=3+Math.floor(rng()*7);
      for(let k=0;k<nF;k++){
        const tF=0.25+(k/(nF-1))*0.70;
        flowers.push({t:tF,side:(k%2===0)?-1:1,offsetX:(rng()-.5)*5*SC,size:0.72+rng()*0.52,hangVar:(rng()-.5)*0.4});
      }
      const needles=[];
      const nN=5+Math.floor(rng()*8);
      for(let l=0;l<nN;l++){
        const tN=0.05+(l/(nN-1))*0.55;
        needles.push({t:tN,side:(l%2===0)?-1:1,len:(3.5+rng()*4.5)*SC,angleOff:(rng()-.5)*0.35});
      }
      subs.push({t:tBr,angle:subAngle,len:subLen,side:subSide,flowers,needles});
    }
    const primNeedles=[];
    const nPN=7+Math.floor(rng()*7);
    for(let l=0;l<nPN;l++){
      const tN=0.05+(l/(nPN-1))*0.52;
      primNeedles.push({t:tN,side:(l%2===0)?-1:1,len:(3+rng()*4)*SC,angleOff:(rng()-.5)*0.3});
    }
    branches.push({origin,tStem:tS,angle:brAngle,len:brLen,side,subs,primNeedles});
  }
  PLANT={ms,branches};
}

// ── DRAWING ──
function drawNeedle(x,y,angle,len,c2,opacity){
  ctx.save(); ctx.translate(x,y); ctx.rotate(angle);
  ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(len,0);
  ctx.strokeStyle=col(c2,opacity); ctx.lineWidth=0.9*SC; ctx.lineCap='round'; ctx.stroke();
  ctx.restore();
}

function drawBell(x,y,w,h,angle,c1,c2,shrivel,opacity){
  const sw=w*(1-shrivel*0.28); const sh=h*(1+shrivel*0.45);
  ctx.save(); ctx.translate(x,y); ctx.rotate(angle);
  ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(0,-2.5*SC);
  ctx.strokeStyle=col(c2,opacity*0.6); ctx.lineWidth=0.7*SC; ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(-sw*.12,0);
  ctx.bezierCurveTo(-sw*.52,sh*.22,-sw*.58,sh*.62,-sw*.46,sh*.88);
  ctx.bezierCurveTo(-sw*.32,sh*1.04,-sw*.12,sh*1.10,0,sh*1.10);
  ctx.bezierCurveTo(sw*.12,sh*1.10,sw*.32,sh*1.04,sw*.46,sh*.88);
  ctx.bezierCurveTo(sw*.58,sh*.62,sw*.52,sh*.22,sw*.12,0);
  ctx.closePath();
  const g=ctx.createLinearGradient(-sw*.5,0,sw*.5,sh);
  g.addColorStop(0,col(c2,opacity*.92));
  g.addColorStop(.45,col(c1,opacity));
  g.addColorStop(1,col(lerpC(c2,[8,4,12],.45),opacity*.78));
  ctx.fillStyle=g; ctx.fill();
  ctx.beginPath();
  ctx.moveTo(-sw*.1,sh*.08);
  ctx.bezierCurveTo(-sw*.38,sh*.28,-sw*.42,sh*.58,-sw*.32,sh*.78);
  ctx.strokeStyle=`rgba(255,255,255,${(0.14*opacity*(1-shrivel*.8)).toFixed(3)})`;
  ctx.lineWidth=sw*.14; ctx.stroke();
  const og=ctx.createRadialGradient(0,sh,0,0,sh,sw*.42);
  og.addColorStop(0,`rgba(0,0,0,${(0.45*opacity).toFixed(3)})`);
  og.addColorStop(1,`rgba(0,0,0,0)`);
  ctx.beginPath(); ctx.ellipse(0,sh,sw*.42,sw*.15,0,0,Math.PI*2);
  ctx.fillStyle=og; ctx.fill();
  ctx.restore();
}

function drawBranch(bx,by,angle,len,subs,primNeedles,p){
  const d=p.droop;
  const naturalEndX=bx+Math.cos(angle)*len;
  const naturalEndY=by+Math.sin(angle)*len;
  const droopEndX=bx+Math.cos(angle)*len*0.5;
  const droopEndY=by+Math.sin(angle)*len*0.5+len*d;
  const endX=lerp(naturalEndX,droopEndX,d*.85);
  const endY=lerp(naturalEndY,droopEndY,d*.85);
  const ctrlX=bx+Math.cos(angle)*len*.42;
  const ctrlY=by+Math.sin(angle)*len*.42;
  ctx.save();
  ctx.beginPath(); ctx.moveTo(bx,by); ctx.quadraticCurveTo(ctrlX,ctrlY,endX,endY);
  ctx.strokeStyle=col(p.stem,.82); ctx.lineWidth=1.6*SC; ctx.lineCap='round'; ctx.stroke();
  ctx.restore();
  primNeedles.forEach(nd=>{
    const pt=qPt(bx,by,ctrlX,ctrlY,endX,endY,nd.t);
    const ta=qTan(bx,by,ctrlX,ctrlY,endX,endY,nd.t);
    const na=ta+nd.side*(Math.PI*.38+d*.4)+nd.angleOff;
    const no=0.65-d*.32;
    if(no>0.04) drawNeedle(pt.x,pt.y,na,nd.len*(1-d*.18),p.lf,no);
  });
  subs.forEach(sub=>{
    const sp=qPt(bx,by,ctrlX,ctrlY,endX,endY,sub.t);
    const sd=d*.9; const sLen=sub.len*(1-d*.10);
    const sNEX=sp.x+Math.cos(sub.angle)*sLen;
    const sNEY=sp.y+Math.sin(sub.angle)*sLen;
    const sDEX=sp.x+Math.cos(sub.angle)*sLen*.4;
    const sDEY=sp.y+Math.sin(sub.angle)*sLen*.4+sLen*sd;
    const sEX=lerp(sNEX,sDEX,sd*.88);
    const sEY=lerp(sNEY,sDEY,sd*.88);
    const sCX=sp.x+Math.cos(sub.angle)*sLen*.4;
    const sCY=sp.y+Math.sin(sub.angle)*sLen*.4;
    ctx.save();
    ctx.beginPath(); ctx.moveTo(sp.x,sp.y); ctx.quadraticCurveTo(sCX,sCY,sEX,sEY);
    ctx.strokeStyle=col(p.stem,.68); ctx.lineWidth=0.9*SC; ctx.lineCap='round'; ctx.stroke();
    ctx.restore();
    sub.needles.forEach(nd=>{
      const npt=qPt(sp.x,sp.y,sCX,sCY,sEX,sEY,nd.t);
      const na=sub.angle+nd.side*(Math.PI*.4+sd*.35)+nd.angleOff;
      const no=0.60-sd*.30;
      if(no>0.04) drawNeedle(npt.x,npt.y,na,nd.len*(1-d*.15),p.lf,no);
    });
    const fW=4.8*SC*p.fscale; const fH=8.0*SC*p.fscale;
    sub.flowers.forEach(fl=>{
      const fpt=qPt(sp.x,sp.y,sCX,sCY,sEX,sEY,fl.t);
      const sTan=qTan(sp.x,sp.y,sCX,sCY,sEX,sEY,fl.t);
      const ha=sTan+fl.side*(Math.PI*.32)+Math.PI*.5*.75+fl.hangVar+d*Math.PI*.28;
      const fo=clamp(1.0-d*.48,.1,1.0);
      if(p.fscale>0.08) drawBell(fpt.x+fl.offsetX,fpt.y,fW*fl.size,fH*fl.size,ha,p.f1,p.f2,p.shrivel,fo);
    });
  });
}

function drawBg(p){
  const bg=p.bg; const lighter=lerpC(bg,[35,25,18],.3);
  const rg=ctx.createRadialGradient(W*.5,H*.42,0,W*.5,H*.42,W*.88);
  rg.addColorStop(0,col(lighter)); rg.addColorStop(1,col(bg));
  ctx.fillStyle=rg; ctx.fillRect(0,0,W,H);
  const vg=ctx.createRadialGradient(W/2,H/2,W*.18,W/2,H/2,W*.82);
  vg.addColorStop(0,'rgba(0,0,0,0)'); vg.addColorStop(1,'rgba(0,0,0,0.60)');
  ctx.fillStyle=vg; ctx.fillRect(0,0,W,H);
}

function drawSoil(){
  const sx=W*.5, sy=H*.875+10*SC;
  ctx.save();
  ctx.beginPath(); ctx.ellipse(sx,sy,58*SC,13*SC,0,0,Math.PI*2);
  const sg=ctx.createRadialGradient(sx,sy-4*SC,0,sx,sy,65*SC);
  sg.addColorStop(0,'rgba(68,44,22,0.92)');
  sg.addColorStop(.7,'rgba(42,26,12,0.88)');
  sg.addColorStop(1,'rgba(18,10,4,0.85)');
  ctx.fillStyle=sg; ctx.fill();
  ctx.beginPath(); ctx.ellipse(sx,sy-2*SC,55*SC,9*SC,0,Math.PI,Math.PI*2);
  ctx.strokeStyle='rgba(95,62,30,0.28)'; ctx.lineWidth=1.2; ctx.stroke();
  ctx.restore();
}

function drawMainStem(p){
  const ms=PLANT.ms; const d=p.droop;
  const ms2={x0:ms.x0,y0:ms.y0,x1:ms.x1+d*12,y1:ms.y1+d*6,x2:ms.x2+d*8,y2:ms.y2,x3:ms.x3,y3:ms.y3};
  const mg=ctx.createLinearGradient(0,ms2.y0,0,ms2.y3);
  mg.addColorStop(0,col(p.stem,.95));
  mg.addColorStop(.6,col(p.stem,.9));
  mg.addColorStop(1,col(lerpC(p.stem,[14,9,5],.4),.8));
  ctx.save();
  ctx.beginPath(); ctx.moveTo(ms2.x0,ms2.y0); ctx.bezierCurveTo(ms2.x1,ms2.y1,ms2.x2,ms2.y2,ms2.x3,ms2.y3);
  ctx.strokeStyle=mg; ctx.lineWidth=3.8*SC; ctx.lineCap='round'; ctx.stroke();
  ctx.strokeStyle='rgba(0,0,0,0.10)'; ctx.lineWidth=3.8*SC*.35; ctx.stroke();
  ctx.restore();
}

function draw(prog){
  const p=getParams(prog);
  drawBg(p); drawSoil(); drawMainStem(p);
  const sorted=PLANT.branches
    .map(br=>({br,depth:Math.abs(br.origin.x-W*.5)/W}))
    .sort((a,b)=>b.depth-a.depth);
  sorted.forEach(({br})=>{
    drawBranch(br.origin.x,br.origin.y,br.angle,br.len,br.subs,br.primNeedles,p);
  });
  const sn=Math.min(Math.floor(prog)+1,10);
  const lb=LABELS[Math.floor(clamp(prog,0,9))];
  const el=document.getElementById('stageEl');
  el.textContent=`STAGE ${String(sn).padStart(2,'0')} / 10  ·  ${lb}`;
  el.className='stage'+(prog>5.5?' red':'');
}

// ── ANIMATION STATE ──
const TOTAL=9.0, MS_PER_STAGE=5000;
let progress=0, speedFactor=1, lastTs=null;
let stemTouchId=null, stemDragY=null;
let activePointers=new Map();

function getCanvasX(cx2){ const r=cv.getBoundingClientRect(); return cx2-r.left; }
function getCanvasY(cy2){ const r=cv.getBoundingClientRect(); return cy2-r.top; }
function inStem(cx2){ const lx=getCanvasX(cx2); return lx>W*.35&&lx<W*.65; }

function setSpeed(mode){
  const el=document.getElementById('speedTag');
  if(mode==='fast'){ speedFactor=3.2; el.textContent='▲ FAST'; el.classList.add('show'); }
  else if(mode==='slow'){ speedFactor=0.18; el.textContent='▼ SLOW'; el.classList.add('show'); }
  else{ speedFactor=1.0; el.classList.remove('show'); }
}

cv.addEventListener('pointerdown',e=>{
  const lx=getCanvasX(e.clientX), ly=getCanvasY(e.clientY);
  activePointers.set(e.pointerId,{x:lx,y:ly});
  if(inStem(e.clientX)){ stemTouchId=e.pointerId; stemDragY=ly; setSpeed('slow'); }
  else setSpeed('fast');
  cv.setPointerCapture(e.pointerId);
});
cv.addEventListener('pointermove',e=>{
  const ly=getCanvasY(e.clientY);
  if(e.pointerId===stemTouchId){
    const dy=Math.abs(ly-(stemDragY||ly)); stemDragY=ly;
    if(dy>0.5) setSpeed('slow');
  }
});
cv.addEventListener('pointerup',e=>{
  activePointers.delete(e.pointerId);
  if(e.pointerId===stemTouchId) stemTouchId=null;
  if(activePointers.size===0) setSpeed(null);
});
cv.addEventListener('pointercancel',e=>{
  activePointers.delete(e.pointerId);
  if(e.pointerId===stemTouchId) stemTouchId=null;
  if(activePointers.size===0) setSpeed(null);
});

window.restart=function(){
  progress=0; lastTs=null; setSpeed(null);
  const el=document.getElementById('stageEl');
  el.textContent='STAGE 01 / 10 · LIVING'; el.className='stage';
};

function animate(ts){
  if(!lastTs) lastTs=ts;
  const dt=Math.min(ts-lastTs,80); lastTs=ts;
  if(progress<TOTAL){ progress+=dt/MS_PER_STAGE*speedFactor; progress=Math.min(progress,TOTAL); }
  draw(progress);
  requestAnimationFrame(animate);
}

buildPlant();
requestAnimationFrame(animate);
</script>

</body>
</html>